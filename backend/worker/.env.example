# =============================================================================
# SideQuest Ingestion Worker — Environment Variables
# =============================================================================
# Copy this to .env and fill in real values.

# --- Supabase (REQUIRED) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# --- Worker Identity ---
WORKER_ID=worker-local-1

# --- Event Source API Keys ---
TICKETMASTER_API_KEY=your-ticketmaster-consumer-key
EVENTBRITE_PRIVATE_TOKEN=your-eventbrite-oauth-token

# --- Review Enrichment ---
# Primary: Google Maps HTML scraping (no API key needed)
# Secondary fallback only — used when scraping misses a venue:
GOOGLE_PLACES_API_KEY=

# --- Optional: Apify for Google Events scraping ---
APIFY_API_TOKEN=your-apify-token

# --- Optional: Yelp for venue discovery ---
YELP_API_KEY=your-yelp-api-key

# --- Worker Tuning ---
POLL_INTERVAL_MS=10000
HEARTBEAT_INTERVAL_MS=30000
MAX_CONCURRENT_JOBS=2
HEARTBEAT_TIMEOUT_MINUTES=5
